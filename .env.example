# Environment Configuration Example
# Copy this file to .env.local and fill in actual values

# Node Environment
NODE_ENV=development
LOG_LEVEL=debug

# Server
PORT=8080
HOST=0.0.0.0

# Database (Optional - if you want to connect to PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/tempsynth
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=tempsynth
# DATABASE_PASSWORD=your_password
# DATABASE_NAME=tempsynth

# API Configuration
API_PORT=8080
API_URL=http://localhost:8080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Logging
LOG_FORMAT=json
LOG_LEVEL=info

# CORS Settings
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Session/Auth (if needed)
# SESSION_SECRET=your-secret-key-here
# JWT_SECRET=your-jwt-secret-here

# External Services (if any)
# STRIPE_KEY=your-stripe-key
# SENDGRID_API_KEY=your-sendgrid-key
